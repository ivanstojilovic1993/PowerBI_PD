	measure 'KPI_Total_Documents_Reviewed HTML' = ```
			
			VAR _count = 
			[No.ofDocs Reviewed]
			VAR _formatted = FORMAT(_count, "#,##0")
			
			RETURN
			"<div style='font-family:Segoe UI,sans-serif;background:transparent;border-left:4px solid #321850;padding:8px 16px;height:100%;box-sizing:border-box;display:flex;flex-direction:column;justify-content:center;'>
			  <div style='font-size:11px;color:#888888;text-transform:uppercase;letter-spacing:0.8px;margin-bottom:6px;'>
			    Reviewed Documents
			  </div>
			  <div style='font-size:24px;font-weight:600;color:#1a1a2e;line-height:1;'>
			    " & _formatted & "
			  </div>
			  <div style='font-size:11px;color:#aaaaaa;margin-top:6px;'>
			    Source: Aconex
			  </div>
			</div>"
			```
		lineageTag: 912e9d79-6df0-452b-8bd5-00784b617a57

