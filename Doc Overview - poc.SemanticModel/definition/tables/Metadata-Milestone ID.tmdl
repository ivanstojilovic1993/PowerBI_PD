	partition 'Metadata-Milestone ID' = m
		mode: import
		source = ```
				let
				    Source = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"# " = _t, #"Milestone description contract" = _t, #"Documentation / Deliverable " = _t, #"Metadata Aconex proposal" = _t, Aconex_key = _t, Primavera = _t]),
				    
				    #"Filtered Rows" = Table.SelectRows(Source, each ([Metadata Aconex proposal] <> "M1" and [Metadata Aconex proposal] <> "M2" and [Metadata Aconex proposal] <> "M3" and [Metadata Aconex proposal] <> "M4" and [Metadata Aconex proposal] <> "M5" and [Metadata Aconex proposal] <> "M6" and [Metadata Aconex proposal] <> "M7")),
				    
				    #"Changed Type" = Table.TransformColumnTypes(#"Filtered Rows",{{"# ", type text}, {"Milestone description contract", type text}, {"Documentation / Deliverable ", type text}, {"Metadata Aconex proposal", type text}}),
				    
				    #"Inserted Text Before Delimiter" = Table.AddColumn(#"Changed Type", "Text Before Delimiter", each Text.BeforeDelimiter([Metadata Aconex proposal], "-"), type text),
				    
				    #"Renamed Columns" = Table.RenameColumns(#"Inserted Text Before Delimiter",{{"Text Before Delimiter", "P9_key"}}),
				    
				    #"Removed Columns" = Table.RemoveColumns(#"Renamed Columns",{"Metadata Aconex proposal"}),
				    #"Replaced Value1" = Table.ReplaceValue(#"Removed Columns","WTG Delivery Certificate Pre","WTG Delivery Certificate Pre-assembly Harbour",Replacer.ReplaceText,{"P9_key"}),
				    // ── Merge 1: Aconex all ──────────────────────────────────────────────────
				    #"Merged Queries" = Table.NestedJoin(#"Replaced Value1", {"Aconex_key"}, #"Aconex all", {"Milestone ID"}, "Aconex all", JoinKind.LeftOuter),
				    #"Expanded Aconex all" = Table.ExpandTableColumn(#"Merged Queries", "Aconex all",
				        {"Document No", "Title", "Revision", "Discipline", "Type", "Doc. Nature", "Status", "Review Status",
				         "Contractual Date Aconex", "Actual issue date", "Required in Final Documentation?",
				         "Final Documentation Book", "Section", "Volume/Sub-section", "MWS Review?", "CB Review?",
				         "Comments", "Title - Copy.1"},
				        {"Aconex.Document No", "Aconex.Title", "Aconex.Revision", "Aconex.Discipline", "Aconex.Type",
				         "Aconex.Doc. Nature", "Aconex.Status", "Aconex.Review Status", "Aconex.Contractual Date",
				         "Aconex.Actual Issue Date", "Aconex.Required in Final Documentation?",
				         "Aconex.Final Documentation Book", "Aconex.Section", "Aconex.Volume/Sub-section",
				         "Aconex.MWS Review?", "Aconex.CB Review?", "Aconex.Comments", "Aconex.Title Copy"}),
				
				    #"Lowercased Text" = Table.TransformColumns(#"Expanded Aconex all",{{"Aconex.Title Copy", Text.Lower, type text}}),
				    #"Trimmed Text"    = Table.TransformColumns(#"Lowercased Text",{{"Aconex.Title Copy", Text.Trim, type text}, {"P9_key", Text.Trim, type text}}),
				
				    // ── Merge 2: Primavera all (M10 – triple key) ───────────────────────────
				    #"Merged Queries1" = Table.NestedJoin(#"Trimmed Text",
				        {"P9_key", "Aconex.Volume/Sub-section", "Aconex.Title Copy"},
				        #"Primavera all",
				        {"COU | Cert Docu", "WTG IDs", "M10"},
				        "Primavera all", JoinKind.LeftOuter),
				    #"Expanded Primavera M10" = Table.ExpandTableColumn(#"Merged Queries1", "Primavera all",
				        {"Activity ID", "Activity Name", "StartDatePrimavera", "FinishDatePrimavera"},
				        {"Primavera.M10.Activity ID", "Primavera.M10.Activity Name",
				         "Primavera.M10.Start Date",  "Primavera.M10.Finish Date"}),
				
				    // ── Merge 3: Primavera all (fallback – double key) ───────────────────────
				    #"Merged Queries2" = Table.NestedJoin(#"Expanded Primavera M10",
				        {"P9_key", "Aconex.Volume/Sub-section"},
				        #"Primavera all",
				        {"COU | Cert Docu", "WTG IDs"},
				        "Primavera all", JoinKind.LeftOuter),
				
				    #"Expanded Primavera Fallback" = Table.ExpandTableColumn(#"Merged Queries2", "Primavera all",
				        {"Activity ID", "Activity Name", "StartDatePrimavera", "FinishDatePrimavera"},
				        {"Primavera.Fallback.Activity ID", "Primavera.Fallback.Activity Name",
				         "Primavera.Fallback.Start Date",  "Primavera.Fallback.Finish Date"}),
				    // ── Coalesce: prefer M10 match, fall back to double-key match ───────────
				    #"Added activity_id"      = Table.AddColumn(#"Expanded Primavera Fallback", "Primavera.Activity ID",
				        each if [Primavera.M10.Activity ID]   <> null then [Primavera.M10.Activity ID]   else [Primavera.Fallback.Activity ID]),
				    #"Added activity_name"    = Table.AddColumn(#"Added activity_id",           "Primavera.Activity Name",
				        each if [Primavera.M10.Activity Name] <> null then [Primavera.M10.Activity Name] else [Primavera.Fallback.Activity Name]),
				    #"Added start_date"       = Table.AddColumn(#"Added activity_name",         "Primavera.Start Date",
				        each if [Primavera.M10.Start Date]    <> null then [Primavera.M10.Start Date]    else [Primavera.Fallback.Start Date]),
				    #"Added finish_date"      = Table.AddColumn(#"Added start_date",            "Primavera.Finish Date",
				        each if [Primavera.M10.Finish Date]   <> null then [Primavera.M10.Finish Date]   else [Primavera.Fallback.Finish Date]),
				
				    // ── Cleanup: remove all intermediate helper columns ───────────────────────
				    #"Removed Intermediate Columns" = Table.RemoveColumns(#"Added finish_date",
				        {"Primavera.M10.Activity ID",   "Primavera.M10.Activity Name",
				         "Primavera.M10.Start Date",    "Primavera.M10.Finish Date",
				         "Primavera.Fallback.Activity ID", "Primavera.Fallback.Activity Name",
				         "Primavera.Fallback.Start Date",  "Primavera.Fallback.Finish Date"}),
				
				    #"Changed Type1" = Table.TransformColumnTypes(#"Removed Intermediate Columns",
				        {{"Primavera.Start Date", type date}, {"Primavera.Finish Date", type date}}),
				    #"Duplicated Column" = Table.DuplicateColumn(#"Changed Type1", "# ", "#  - Copy"),
				    #"Replaced Value" = Table.ReplaceValue(#"Duplicated Column","a","1",Replacer.ReplaceText,{"#  - Copy"}),
				    #"Changed Type2" = Table.TransformColumnTypes(#"Replaced Value",{{"#  - Copy", type number}}),
				    #"Renamed Columns1" = Table.RenameColumns(#"Changed Type2",{{"#  - Copy", "Sort"}}),
				    #"Changed Type with Locale" = Table.TransformColumnTypes(#"Renamed Columns1", {{"Aconex.Contractual Date", type date}}, "en-GB"),
				    #"Changed Type3" = Table.TransformColumnTypes(#"Changed Type with Locale",{{"Aconex.Actual Issue Date", type date}},"en-GB")
				in
				    #"Changed Type3"
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

