model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup All

	annotation PBI_QueryGroupOrder = 2

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Metadata-Milestone ID","WTG ID","Aconex all","Primavera all"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Metadata-Milestone ID'
ref table 'Aconex all'
ref table 'Primavera all'
ref table 'WTG ID'

ref cultureInfo en-US

